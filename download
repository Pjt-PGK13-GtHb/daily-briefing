<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0a0a0c">
<title>Daily Briefing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@500;600;700;800&family=Playfair+Display:wght@500;600;700;800&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=Tiro+Devanagari+Hindi&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:'Inter',sans-serif;font-size:15px;line-height:1.65;min-height:100vh;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}

/* ══════════ THEME: AI — Terminal/Signal Console ══════════ */
body.theme-ai{
  --ink:#e8e8ea;--ink-2:#9a9aa3;--ink-3:#6b6b75;--ink-4:#4a4a54;
  --surface:#121214;--surface-2:#0a0a0b;--surface-3:#1a1a1d;
  --border:rgba(255,255,255,.08);--border-2:rgba(255,255,255,.16);
  --accent:#00d4c8;--accent-bg:rgba(0,212,200,.12);
  --green:#4ade80;--green-bg:rgba(74,222,128,.1);
  --amber:#ffb454;--amber-bg:rgba(255,180,84,.12);
  --coral:#ff6b6b;--coral-bg:rgba(255,107,107,.12);
  --hero-bg:#08080a;--hero-g1:rgba(0,212,200,.16);--hero-g2:rgba(255,180,84,.1);
  --df:'Sora',sans-serif;--mono:'JetBrains Mono',monospace;--r:10px;--r-sm:6px;
  background:var(--surface-2);color:var(--ink);
  background-image:linear-gradient(rgba(0,212,200,.028) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,200,.028) 1px,transparent 1px);
  background-size:32px 32px;background-attachment:fixed;
}
body.theme-ai::before{content:'';position:fixed;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,#00d4c8,transparent);opacity:.5;
  z-index:9999;animation:scanline 6s linear infinite;pointer-events:none}
@keyframes scanline{0%{transform:translateY(0);opacity:0}5%{opacity:.6}95%{opacity:.6}100%{transform:translateY(100vh);opacity:0}}
body.theme-ai .card,body.theme-ai .s-card,body.theme-ai .modal{background:var(--surface)}
body.theme-ai .fbtn{background:var(--surface)}
body.theme-ai .lnk,body.theme-ai .lstep{background:var(--surface-3)}
body.theme-ai header{background:var(--surface-2);border-bottom-color:var(--border)}

/* ══════════ THEME: FINANCE — Indian bullion elegance ══════════ */
body.theme-finance{
  --ink:#1a1408;--ink-2:#4a3e22;--ink-3:#7a6a45;--ink-4:#b0a075;
  --surface:#fffdf7;--surface-2:#faf5e8;--surface-3:#f2e9d2;
  --border:rgba(122,90,20,.16);--border-2:rgba(122,90,20,.28);
  --accent:#9c7a1f;--accent-bg:#f6ecc9;
  --green:#0d6b42;--green-bg:#e7f3ea;
  --amber:#a8460a;--amber-bg:#fbeade;
  --coral:#8c2f2f;--coral-bg:#f8e8e6;
  --hero-bg:#0f2b1f;--hero-g1:rgba(212,168,67,.25);--hero-g2:rgba(13,107,66,.22);
  --df:'Playfair Display',serif;--mono:'Inter',sans-serif;--r:6px;--r-sm:4px;
  background:var(--surface-2);color:var(--ink);
}

/* ══════════ THEME: WORLD — Bold magazine, high contrast ══════════ */
body.theme-world{
  --ink:#0a0a0a;--ink-2:#2a2a2a;--ink-3:#666;--ink-4:#999;
  --surface:#fff;--surface-2:#f5f5f5;--surface-3:#ebebeb;
  --border:rgba(0,0,0,.1);--border-2:rgba(0,0,0,.2);
  --accent:#d41f1f;--accent-bg:#fceaea;
  --green:#1a6e30;--green-bg:#e8f5eb;
  --amber:#b35c00;--amber-bg:#fff0e0;
  --coral:#c02020;--coral-bg:#fceaea;
  --hero-bg:#0a0a0a;--hero-g1:rgba(212,31,31,.2);--hero-g2:rgba(255,200,0,.12);
  --df:'Bebas Neue',sans-serif;--mono:'DM Sans',sans-serif;--r:4px;--r-sm:2px;
  background:var(--surface-2);color:var(--ink);
}
body.theme-world .hero-title{letter-spacing:.04em;text-transform:uppercase}
body.theme-world .card{border-radius:0;border-left:4px solid var(--accent);border-top:none;border-right:none;border-bottom:1px solid var(--border)}
body.theme-world .card-title{font-family:'DM Sans',sans-serif;font-weight:700;font-size:15px;text-transform:uppercase;letter-spacing:.02em}
body.theme-world .card-num{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--accent);min-width:36px}
body.theme-world .card.open .card-num{color:var(--ink)}
body.theme-world .sod-card{border-left:6px solid #ffd700}
body.theme-world .fbtn{border-radius:2px;text-transform:uppercase;letter-spacing:.06em;font-size:11px}
body.theme-world .fbtn.on{background:var(--accent);border-color:var(--accent)}
body.theme-world .section-lbl{font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:14px;text-transform:uppercase}
body.theme-world .s-title{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:11px;color:var(--ink-3)}

/* ══════════ THEME: INDIA — Saffron & Ashoka Blue ══════════ */
body.theme-india{
  --ink:#1a0f00;--ink-2:#3d2800;--ink-3:#7a5c2e;--ink-4:#b08850;
  --surface:#fffbf5;--surface-2:#fff7eb;--surface-3:#f5e8cc;
  --border:rgba(180,100,0,.15);--border-2:rgba(180,100,0,.28);
  --accent:#FF9933;--accent-bg:rgba(255,153,51,.12);
  --green:#138808;--green-bg:rgba(19,136,8,.1);
  --amber:#c17d00;--amber-bg:#fff3cc;
  --coral:#c0392b;--coral-bg:#fde8e6;
  --blue:#000080;--blue-bg:rgba(0,0,128,.08);
  --hero-bg:#1a0f00;--hero-g1:rgba(255,153,51,.25);--hero-g2:rgba(19,136,8,.18);
  --df:'Playfair Display',serif;--mono:'DM Sans',sans-serif;--r:8px;--r-sm:5px;
  background:var(--surface-2);color:var(--ink);
}
body.theme-india .hero-title em{color:#FF9933}
body.theme-india .sod-label{color:#FF9933}
body.theme-india .sod-card{background:linear-gradient(135deg,#1a0f00 0%,#0d1a00 100%);border:1px solid rgba(255,153,51,.3)}
body.theme-india .sod-card::after{content:'🇮🇳';font-size:40px}
body.theme-india .accent{color:var(--accent)}
body.theme-india .card-num{color:#FF9933}
body.theme-india .card.open .card-num{color:#138808}
body.theme-india .section-lbl{font-family:'Playfair Display',serif;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.06em}
body.theme-india .chennai-divider{
  background:linear-gradient(90deg,#FF9933,#fff,#138808);
  height:3px;margin:28px 0 20px;border-radius:2px;
}

/* ══════════ THEME: SPORTS — Stadium energy ══════════ */
body.theme-sports{
  --ink:#f0f0f0;--ink-2:#c0c0c8;--ink-3:#808090;--ink-4:#505060;
  --surface:#1a1a22;--surface-2:#13131a;--surface-3:#222230;
  --border:rgba(255,255,255,.08);--border-2:rgba(255,255,255,.15);
  --accent:#f0c000;--accent-bg:rgba(240,192,0,.12);
  --green:#22dd77;--green-bg:rgba(34,221,119,.1);
  --amber:#ff8c00;--amber-bg:rgba(255,140,0,.12);
  --coral:#ff4455;--coral-bg:rgba(255,68,85,.12);
  --hero-bg:#0a0a10;--hero-g1:rgba(240,192,0,.2);--hero-g2:rgba(255,68,85,.12);
  --df:'Bebas Neue',sans-serif;--mono:'DM Sans',sans-serif;--r:8px;--r-sm:5px;
  background:var(--surface-2);color:var(--ink);
}
body.theme-sports .hero-title{letter-spacing:.06em;text-transform:uppercase}
body.theme-sports .hero-title em{color:#f0c000}
body.theme-sports .card,body.theme-sports .s-card{background:var(--surface)}
body.theme-sports .fbtn{background:var(--surface)}
body.theme-sports .lnk,body.theme-sports .lstep{background:var(--surface-3)}
body.theme-sports .card-num{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--ink-4);min-width:36px}
body.theme-sports .card.open .card-num{color:#f0c000}
body.theme-sports .card-title{font-family:'DM Sans',sans-serif;font-weight:700}
body.theme-sports .sod-card{background:linear-gradient(135deg,#1a1000 0%,#0a0a10 100%);border:1px solid rgba(240,192,0,.3)}
body.theme-sports .sod-label{color:#f0c000}
body.theme-sports .sod-card::after{content:'🏆';font-size:40px}
body.theme-sports .sport-tabs{display:flex;gap:0;margin-bottom:20px;overflow-x:auto;scrollbar-width:none;border-bottom:2px solid var(--border)}
body.theme-sports .sport-tab{padding:10px 18px;background:transparent;border:none;color:var(--ink-3);font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:.06em;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:all .15s;-webkit-tap-highlight-color:transparent}
body.theme-sports .sport-tab:hover{color:var(--ink)}
body.theme-sports .sport-tab.active{color:#f0c000;border-bottom-color:#f0c000}
body.theme-sports .section-lbl{font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:14px;text-transform:uppercase}
body.theme-sports .modal{background:var(--surface)}

/* ══════════ TAB SWITCHER ══════════ */
.tab-switcher{display:flex;background:#0a0a0c;position:sticky;top:0;z-index:300;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid rgba(255,255,255,.06)}
.tab-switcher::-webkit-scrollbar{display:none}
.tab-btn{flex:1;min-width:100px;display:flex;align-items:center;justify-content:center;gap:6px;padding:12px 14px;background:transparent;border:none;color:rgba(255,255,255,.4);font-family:'Inter',sans-serif;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;transition:color .2s,border-color .2s,background .2s;-webkit-tap-highlight-color:transparent}
.tab-btn:hover{color:rgba(255,255,255,.75)}
.tab-btn.active{color:#fff}
body.theme-ai      .tab-btn.active{border-color:#00d4c8;background:rgba(0,212,200,.08)}
body.theme-finance .tab-btn.active{border-color:#d4a843;background:rgba(212,168,67,.1)}
body.theme-world   .tab-btn.active{border-color:#d41f1f;background:rgba(212,31,31,.1)}
body.theme-india   .tab-btn.active{border-color:#FF9933;background:rgba(255,153,51,.1)}
body.theme-sports  .tab-btn.active{border-color:#f0c000;background:rgba(240,192,0,.08)}

/* ══════════ TICKER ══════════ */
.ticker-wrap{height:34px;display:flex;align-items:center;overflow:hidden;background:#0a0a0c}
.ticker-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:0 12px;height:34px;display:flex;align-items:center;white-space:nowrap;flex-shrink:0;color:#fff}
body.theme-ai      .ticker-label{background:transparent;color:#00d4c8;font-family:var(--mono);border-right:1px solid rgba(0,212,200,.2)}
body.theme-finance .ticker-label{background:#9c7a1f}
body.theme-world   .ticker-label{background:#d41f1f}
body.theme-india   .ticker-label{background:#FF9933;color:#fff}
body.theme-sports  .ticker-label{background:#f0c000;color:#0a0a10}
.ticker-scroll{overflow:hidden;flex:1}
.ticker-track{display:flex;animation:ticker 55s linear infinite;white-space:nowrap}
.ticker-track span{font-size:11px;color:rgba(255,255,255,.7);padding:0 28px}
.ticker-track span::before{content:"● ";font-size:7px;vertical-align:2px}
body.theme-ai     .ticker-track span{font-family:var(--mono);color:#9a9aa3}
body.theme-ai     .ticker-track span::before{color:#00d4c8}
body.theme-finance .ticker-track span::before{color:#d4a843}
body.theme-world   .ticker-track span::before{color:#d41f1f}
body.theme-india   .ticker-track span::before{color:#FF9933}
body.theme-sports  .ticker-track span::before{color:#f0c000}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ══════════ HEADER ══════════ */
header{background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:48px;z-index:200;box-shadow:0 1px 4px rgba(0,0,0,.06)}
body.theme-ai     header{background:var(--surface-2)}
body.theme-sports header{background:var(--surface)}
body.theme-world  header{border-bottom:3px solid var(--accent)}
.header-inner{max-width:1100px;margin:0 auto;padding:0 16px;height:56px;display:flex;align-items:center;justify-content:space-between;gap:10px}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--ink);flex-shrink:0}
.logo-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;background:var(--accent);color:#fff}
body.theme-ai .logo-icon{box-shadow:0 0 14px rgba(0,212,200,.4)}
body.theme-sports .logo-icon{box-shadow:0 0 14px rgba(240,192,0,.4);color:#0a0a10}
body.theme-world  .logo-icon{border-radius:2px}
.logo-text{font-family:var(--df);font-weight:700;font-size:15px;letter-spacing:-.01em;color:var(--ink)}
.logo-text em{color:var(--accent);font-style:normal}
body.theme-world .logo-text{font-size:20px;letter-spacing:.04em;text-transform:uppercase}
body.theme-sports .logo-text{font-size:20px;letter-spacing:.06em;text-transform:uppercase}
.header-right{display:flex;align-items:center;gap:8px}
.edition-pill{font-size:11px;font-weight:500;color:var(--ink-3);background:var(--surface-3);padding:4px 10px;border-radius:20px;border:1px solid var(--border);white-space:nowrap}
body.theme-ai .edition-pill{font-family:var(--mono);border-color:rgba(0,212,200,.2)}
body.theme-world .edition-pill{border-radius:2px;text-transform:uppercase;letter-spacing:.05em;font-size:10px}
.live-badge{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:500;color:var(--green);white-space:nowrap}
.live-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite;flex-shrink:0}
body.theme-ai .live-badge{font-family:var(--mono);text-transform:uppercase;letter-spacing:.08em;font-size:10px}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
.refresh-btn{display:flex;align-items:center;gap:6px;color:#fff;border:none;border-radius:20px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;transition:opacity .15s,transform .12s;white-space:nowrap;flex-shrink:0;background:var(--accent);-webkit-tap-highlight-color:transparent}
.refresh-btn:hover{opacity:.9}
.refresh-btn:active{transform:scale(.97)}
body.theme-ai    .refresh-btn{color:#08080a;font-family:var(--mono);box-shadow:0 0 18px rgba(0,212,200,.3)}
body.theme-world .refresh-btn{border-radius:2px;text-transform:uppercase;letter-spacing:.06em}
body.theme-sports .refresh-btn{color:#0a0a10}
.ri{font-size:14px;display:inline-block;transition:transform .4s}
.refresh-btn:hover .ri{transform:rotate(180deg)}
@media(max-width:560px){.edition-pill,.live-badge{display:none}.refresh-btn .btn-text{display:none}.refresh-btn{padding:7px 10px}}

/* ══════════ HERO ══════════ */
.hero{background:var(--hero-bg);padding:36px 16px 32px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-100px;right:-60px;width:360px;height:360px;background:radial-gradient(circle,var(--hero-g1) 0%,transparent 70%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-60px;left:-40px;width:260px;height:260px;background:radial-gradient(circle,var(--hero-g2) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:1100px;margin:0 auto;position:relative;z-index:1}
.hero-eyebrow{font-size:10px;font-weight:600;letter-spacing:.13em;text-transform:uppercase;color:rgba(255,255,255,.42);margin-bottom:10px}
body.theme-ai     .hero-eyebrow{font-family:var(--mono);color:#00d4c8;letter-spacing:.2em}
body.theme-ai     .hero-eyebrow::before{content:'> ';opacity:.7}
body.theme-world  .hero-eyebrow{font-family:'DM Sans',sans-serif;font-weight:700;letter-spacing:.18em}
body.theme-sports .hero-eyebrow{font-family:'Bebas Neue',sans-serif;letter-spacing:.2em;font-size:12px}
.hero-title{font-family:var(--df);font-size:clamp(24px,5vw,42px);font-weight:700;color:#fff;line-height:1.15;letter-spacing:-.02em;margin-bottom:14px}
.hero-title em{font-style:normal;color:var(--accent)}
body.theme-ai     .hero-title em{text-shadow:0 0 24px rgba(0,212,200,.35)}
body.theme-finance .hero-title em{font-family:'Spectral',serif;font-style:italic;font-weight:500;color:#d4a843}
body.theme-world  .hero-title{line-height:1.05}
body.theme-sports .hero-title em{text-shadow:0 0 20px rgba(240,192,0,.4)}
.hero-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px}
.hero-pill{font-size:11px;font-weight:500;padding:4px 11px;border-radius:20px;border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.7);background:rgba(255,255,255,.06)}
body.theme-ai    .hero-pill{font-family:var(--mono);border-radius:4px;font-size:10px}
body.theme-world .hero-pill{border-radius:2px}
body.theme-sports .hero-pill{font-family:'DM Sans',sans-serif}
.hero-pill.hi{border-color:rgba(255,255,255,.3)}
body.theme-ai     .hero-pill.hi{background:rgba(0,212,200,.14);color:#00d4c8;border-color:rgba(0,212,200,.35)}
body.theme-finance .hero-pill.hi{background:rgba(212,168,67,.22);color:#f0dca0}
body.theme-world   .hero-pill.hi{background:rgba(212,31,31,.25);color:#ffa0a0;border-color:rgba(212,31,31,.4)}
body.theme-india   .hero-pill.hi{background:rgba(255,153,51,.22);color:#ffd080}
body.theme-sports  .hero-pill.hi{background:rgba(240,192,0,.18);color:#f0c000;border-color:rgba(240,192,0,.35)}
.trend-banner{background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);padding:13px 16px;font-size:13px;color:rgba(255,255,255,.75);line-height:1.65}
body.theme-ai .trend-banner{border-left:2px solid #00d4c8;border-radius:0 var(--r) var(--r) 0}
body.theme-world .trend-banner{border-left:4px solid #d41f1f;border-radius:0}
body.theme-sports .trend-banner{border-left:3px solid #f0c000;border-radius:0 var(--r) var(--r) 0}
.trend-banner strong{color:#fff;font-weight:600}
body.theme-ai    .trend-banner strong{color:#00d4c8;font-family:var(--mono);font-weight:500;font-size:12px}
body.theme-world .trend-banner strong{font-family:'DM Sans',sans-serif;text-transform:uppercase;letter-spacing:.04em}
body.theme-sports .trend-banner strong{color:#f0c000}

/* ══════════ RATE STRIP ══════════ */
.rate-strip{display:none;max-width:1100px;margin:0 auto;padding:0 16px}
body.theme-finance .rate-strip{display:grid}
.rate-strip-inner{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border-2);border:1px solid var(--border-2);border-radius:var(--r);overflow:hidden;margin-top:-18px;position:relative;z-index:2;box-shadow:0 4px 16px rgba(0,0,0,.08)}
@media(max-width:700px){.rate-strip-inner{grid-template-columns:repeat(2,1fr)}}
.rate-cell{background:var(--surface);padding:14px 16px;text-align:center}
.rate-cell-label{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:4px;font-family:'Spectral',serif;font-style:italic}
.rate-cell-value{font-family:var(--df);font-size:18px;font-weight:700;color:var(--ink)}
.rate-cell-delta{font-size:11px;font-weight:600;margin-top:2px}
.rate-cell-delta.up{color:var(--green)}
.rate-cell-delta.down{color:var(--coral)}

/* ══════════ LAYOUT ══════════ */
.page-body{max-width:1100px;margin:0 auto;padding:24px 16px;display:grid;grid-template-columns:1fr 280px;gap:24px;align-items:start}
body.theme-finance .page-body{padding-top:34px}
@media(max-width:820px){.page-body{grid-template-columns:1fr}}
.section-lbl{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.section-lbl::after{content:'';flex:1;height:1px;background:var(--border)}
body.theme-finance .section-lbl{font-family:'Spectral',serif;font-style:italic;letter-spacing:.04em;text-transform:none;font-size:11px}
body.theme-ai      .section-lbl{font-family:var(--mono);color:#00d4c8;font-size:10px}
body.theme-ai      .section-lbl::after{background:linear-gradient(90deg,rgba(0,212,200,.25),transparent)}
body.theme-world   .section-lbl{font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:14px;color:var(--accent)}
body.theme-sports  .section-lbl{font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:14px;color:#f0c000}

/* ══════════ STORY OF DAY ══════════ */
.sod-card{border-radius:var(--r);padding:22px;margin-bottom:18px;position:relative;overflow:hidden}
body.theme-ai      .sod-card{background:linear-gradient(135deg,#0f1f1d 0%,#080d0c 100%);border:1px solid rgba(0,212,200,.25)}
body.theme-finance .sod-card{background:linear-gradient(135deg,#1a3326 0%,#0f2018 100%);border:1px solid rgba(212,168,67,.3)}
body.theme-world   .sod-card{background:linear-gradient(135deg,#1a0000 0%,#0a0a0a 100%);border-left:6px solid #ffd700}
body.theme-india   .sod-card{background:linear-gradient(135deg,#1a0f00 0%,#0d1a00 100%);border:1px solid rgba(255,153,51,.3)}
body.theme-sports  .sod-card{background:linear-gradient(135deg,#1a1000 0%,#0a0a10 100%);border:1px solid rgba(240,192,0,.3)}
.sod-card::after{position:absolute;right:20px;top:16px;font-size:48px;opacity:.08;color:#fff}
body.theme-ai      .sod-card::after{content:'◆';color:#00d4c8;font-family:var(--mono)}
body.theme-finance .sod-card::after{content:'₹';font-family:'Playfair Display',serif}
body.theme-world   .sod-card::after{content:'★';font-family:'Bebas Neue',sans-serif}
.sod-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:7px}
body.theme-ai      .sod-label{color:#00d4c8;font-family:var(--mono)}
body.theme-finance .sod-label{color:#d4a843}
body.theme-world   .sod-label{color:#ffd700;font-family:'DM Sans',sans-serif;letter-spacing:.1em}
body.theme-india   .sod-label{color:#FF9933}
body.theme-sports  .sod-label{color:#f0c000;font-family:'Bebas Neue',sans-serif;letter-spacing:.1em;font-size:11px}
.sod-title{font-family:var(--df);font-size:clamp(15px,3vw,19px);font-weight:700;color:#fff;line-height:1.3;margin-bottom:9px}
.sod-body{font-size:13px;color:rgba(255,255,255,.68);line-height:1.7}

/* ══════════ FILTER BAR ══════════ */
.filter-bar{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:18px}
@media(max-width:600px){.filter-bar{flex-wrap:nowrap;overflow-x:auto;padding-bottom:6px;scrollbar-width:none}.filter-bar::-webkit-scrollbar{display:none}}
.fbtn{font-size:12px;font-weight:500;padding:6px 13px;border-radius:20px;border:1px solid var(--border-2);background:var(--surface);color:var(--ink-2);cursor:pointer;white-space:nowrap;transition:all .12s;flex-shrink:0;-webkit-tap-highlight-color:transparent}
.fbtn:hover,.fbtn.on{background:var(--accent);border-color:var(--accent);color:#fff}
body.theme-ai     .fbtn{font-family:var(--mono);border-radius:4px;font-size:11px;border-color:rgba(255,255,255,.1)}
body.theme-ai     .fbtn:hover,.theme-ai .fbtn.on{background:rgba(0,212,200,.14);border-color:#00d4c8;color:#00d4c8}
body.theme-sports .fbtn{background:var(--surface);border-color:rgba(255,255,255,.1)}
body.theme-sports .fbtn.on{background:rgba(240,192,0,.14);border-color:#f0c000;color:#f0c000}

/* ══════════ CARDS ══════════ */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);margin-bottom:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.07);transition:border-color .15s,box-shadow .15s}
body.theme-ai     .card{box-shadow:none}
body.theme-sports .card{box-shadow:none}
.card:hover{border-color:var(--border-2);box-shadow:0 4px 16px rgba(0,0,0,.1)}
body.theme-ai     .card:hover{border-color:rgba(0,212,200,.3);box-shadow:0 0 20px rgba(0,212,200,.08)}
body.theme-sports .card:hover{border-color:rgba(240,192,0,.3)}
.card-hdr{padding:16px 16px 14px;cursor:pointer;display:flex;gap:12px;align-items:flex-start;-webkit-tap-highlight-color:transparent;user-select:none}
.card-num{font-family:var(--df);font-size:20px;font-weight:700;color:var(--border-2);min-width:30px;line-height:1;padding-top:3px;transition:color .15s}
body.theme-ai .card-num{font-family:var(--mono);font-size:13px;color:var(--ink-4);padding-top:5px}
.card.open .card-num{color:var(--accent)}
body.theme-ai .card.open .card-num{text-shadow:0 0 8px rgba(0,212,200,.5)}
.card-main{flex:1;min-width:0}
.tag-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:7px}
.tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap}
body.theme-ai    .tag{border-radius:3px;font-family:var(--mono)}
body.theme-world .tag{border-radius:2px;text-transform:uppercase;letter-spacing:.04em}
.t-geo{background:var(--coral-bg);color:var(--coral)}
.t-reg{background:var(--amber-bg);color:var(--amber)}
.t-big{background:var(--accent-bg);color:var(--accent)}
.t-res{background:var(--green-bg);color:var(--green)}
.t-biz{background:var(--green-bg);color:var(--green)}
.t-sta{background:var(--green-bg);color:var(--green)}
.t-vir{background:var(--coral-bg);color:var(--coral)}
.t-mkt{background:var(--green-bg);color:var(--green)}
.t-gld{background:var(--amber-bg);color:var(--amber)}
.t-glo{background:var(--accent-bg);color:var(--accent)}
.t-con{background:var(--coral-bg);color:var(--coral)}
.t-pol{background:var(--amber-bg);color:var(--amber)}
.t-cul{background:var(--green-bg);color:var(--green)}
.t-edu{background:var(--accent-bg);color:var(--accent)}
.t-civ{background:var(--green-bg);color:var(--green)}
.t-gov{background:var(--amber-bg);color:var(--amber)}
.t-spt{background:var(--accent-bg);color:var(--accent)}
.t-cri{background:var(--green-bg);color:var(--green)}
.t-fbl{background:var(--coral-bg);color:var(--coral)}
.t-ten{background:var(--amber-bg);color:var(--amber)}
.t-f1{background:var(--accent-bg);color:var(--accent)}
.card-title{font-family:var(--df);font-size:clamp(14px,2.5vw,15px);font-weight:600;color:var(--ink);line-height:1.35;margin-bottom:5px;letter-spacing:-.01em}
body.theme-ai    .card-title{font-weight:500}
body.theme-world .card-title{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;font-size:14px;letter-spacing:.02em}
body.theme-sports .card-title{font-family:'DM Sans',sans-serif;font-weight:700}
.card-why{font-size:12px;color:var(--ink-3);line-height:1.55}
.chevron{font-size:18px;color:var(--ink-4);transition:transform .2s;flex-shrink:0;padding-top:3px;line-height:1}
.card.open .chevron{transform:rotate(180deg)}
.card-body{display:none;border-top:1px solid var(--border);padding:18px 16px}
.card.open .card-body{display:block}
.blabel{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:7px;margin-top:16px}
.blabel:first-child{margin-top:0}
body.theme-finance .blabel{font-family:'Spectral',serif;font-style:italic;letter-spacing:.04em;text-transform:none;font-size:12px}
body.theme-ai      .blabel{font-family:var(--mono);color:#00d4c8;font-size:10px}
body.theme-world   .blabel{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.08em}
body.theme-sports  .blabel{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-3)}
.btext{font-size:13px;color:var(--ink-2);line-height:1.75}
.my-take{background:var(--accent-bg);border-left:3px solid var(--accent);border-radius:0 var(--r-sm) var(--r-sm) 0;padding:11px 13px;font-size:13px;line-height:1.65;font-style:italic;color:var(--ink)}
body.theme-ai      .my-take{color:#7fe8e0;background:rgba(0,212,200,.08);border-left-color:#00d4c8}
body.theme-finance .my-take{color:#5c4912}
body.theme-world   .my-take{border-radius:0;border-left:4px solid #d41f1f}
body.theme-sports  .my-take{background:rgba(240,192,0,.08);border-left-color:#f0c000;color:var(--ink-2)}

/* ══════════ LINK CARDS & LEARNING PATH ══════════ */
.links-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:7px}
.lnk{display:flex;align-items:center;gap:9px;padding:9px 11px;border-radius:var(--r-sm);border:1px solid var(--border);background:var(--surface-2);text-decoration:none;color:var(--ink);font-size:12px;transition:background .12s,border-color .12s;-webkit-tap-highlight-color:transparent}
.lnk:hover{background:var(--surface-3);border-color:var(--border-2)}
body.theme-world  .lnk{border-radius:2px}
body.theme-sports .lnk{background:var(--surface-3)}
.lnk-icon{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.lnk-icon.yt{background:#fce8e8}
.lnk-icon.web{background:var(--accent-bg)}
body.theme-ai .lnk-icon.web{background:rgba(0,212,200,.15)}
body.theme-ai .lnk-icon.yt{background:rgba(255,107,107,.15)}
.lnk-name{font-weight:500;font-size:12px;line-height:1.3}
body.theme-ai .lnk-name{font-family:var(--mono);font-size:11px}
.lnk-kind{font-size:10px;color:var(--ink-4)}
.lpath{display:flex;flex-direction:column;gap:6px}
.lstep{display:flex;align-items:center;gap:11px;padding:10px 13px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-sm);text-decoration:none;color:var(--ink);font-size:13px;transition:background .12s;-webkit-tap-highlight-color:transparent}
.lstep:hover{background:var(--surface-3)}
body.theme-sports .lstep{background:var(--surface-3)}
.lstep-num{width:22px;height:22px;border-radius:50%;background:var(--accent);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
body.theme-ai    .lstep-num{background:rgba(0,212,200,.15);color:#00d4c8;border-radius:4px;font-family:var(--mono)}
body.theme-sports .lstep-num{color:#0a0a10}
body.theme-world .lstep-num{border-radius:2px}
.lstep-body{flex:1}
.lstep-title{font-weight:500;font-size:13px;color:var(--ink)}
body.theme-ai    .lstep-title{font-family:var(--mono);font-size:12px}
body.theme-world .lstep-title{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;font-size:12px;letter-spacing:.04em}
.lstep-desc{font-size:11px;color:var(--ink-3);margin-top:1px}
.lstep-arr{color:var(--ink-4);font-size:14px}

/* ══════════ FINANCE TABLES ══════════ */
.top5-grid{display:grid;grid-template-columns:1fr;gap:14px;margin-bottom:22px}
.top5-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.top5-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface-3)}
.top5-head-title{font-family:'Playfair Display',serif;font-size:14px;font-weight:600;color:var(--ink)}
.top5-head-sub{font-family:'Spectral',serif;font-style:italic;font-size:11px;color:var(--ink-3)}
.top5-table{width:100%;border-collapse:collapse}
.top5-table tr{border-bottom:1px solid var(--border)}
.top5-table tr:last-child{border-bottom:none}
.top5-table td{padding:10px 16px;font-size:12.5px;vertical-align:middle}
.t5-rank{font-family:'Playfair Display',serif;font-weight:700;font-size:14px;color:var(--ink-4);width:28px}
.t5-name{color:var(--ink);font-weight:600}
.t5-meta{color:var(--ink-3);font-size:11px;margin-top:1px}
.t5-val{text-align:right;font-weight:600;color:var(--ink);white-space:nowrap}
.t5-chg{text-align:right;font-size:11px;font-weight:600;white-space:nowrap}
.t5-chg.up{color:var(--green)}.t5-chg.down{color:var(--coral)}
.t5-disclaimer{font-size:11px;color:var(--ink-4);margin:-4px 0 18px;font-family:'Spectral',serif;font-style:italic}

/* ══════════ MULTIBAGGER SECTION ══════════ */
.mb-section{margin-top:28px}
.mb-grid{display:grid;grid-template-columns:1fr;gap:12px;margin-bottom:8px}
.mb-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:border-color .15s,box-shadow .15s}
.mb-card:hover{border-color:var(--border-2);box-shadow:0 4px 16px rgba(122,90,20,.1)}
.mb-hdr{padding:14px 16px;cursor:pointer;display:flex;align-items:flex-start;gap:12px;user-select:none;-webkit-tap-highlight-color:transparent}
.mb-rank{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--border-2);min-width:28px;line-height:1;padding-top:2px;transition:color .15s}
.mb-card.open .mb-rank{color:#9c7a1f}
.mb-main{flex:1;min-width:0}
.mb-tag-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap}
.mb-tag{font-size:10px;font-weight:600;padding:2px 9px;border-radius:20px;background:var(--amber-bg);color:var(--amber);white-space:nowrap}
.mb-ticker{font-family:'Spectral',serif;font-style:italic;font-size:11px;color:var(--ink-3)}
.mb-mcap{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;background:var(--green-bg);color:var(--green)}
.mb-name{font-family:'Playfair Display',serif;font-size:15px;font-weight:600;color:var(--ink);line-height:1.3;margin-bottom:4px}
.mb-sector{font-size:11px;color:var(--ink-3);margin-bottom:4px}
.mb-metric{font-size:11px;color:var(--green);font-weight:500;font-family:'Spectral',serif;font-style:italic}
.mb-chevron{font-size:18px;color:var(--ink-4);transition:transform .2s;flex-shrink:0;padding-top:3px}
.mb-card.open .mb-chevron{transform:rotate(180deg)}
.mb-body{display:none;border-top:1px solid var(--border);padding:16px}
.mb-card.open .mb-body{display:block}
.mb-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
@media(max-width:500px){.mb-row{grid-template-columns:1fr}}
.mb-cell{background:var(--surface-3);border-radius:var(--r-sm);padding:10px 12px}
.mb-cell-label{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:3px;font-family:'Spectral',serif;font-style:italic}
.mb-cell-val{font-size:12px;color:var(--ink-2);line-height:1.5}
.mb-thesis{font-size:13px;color:var(--ink-2);line-height:1.75;margin-bottom:12px}
.mb-risk{background:var(--coral-bg);border-left:3px solid var(--coral);border-radius:0 var(--r-sm) var(--r-sm) 0;padding:9px 12px;font-size:12px;color:var(--coral);font-style:italic;margin-bottom:12px}
.mb-risk::before{content:"⚠️ Risk: ";font-weight:600;font-style:normal}
.mb-disclaimer{font-size:11px;color:var(--ink-4);font-family:'Spectral',serif;font-style:italic;margin-top:8px;line-height:1.6;padding:10px 12px;background:var(--surface-3);border-radius:var(--r-sm)}
@media(max-width:600px){.top5-table td{padding:9px 12px;font-size:11.5px}.t5-meta{display:none}}

/* ══════════ SIDEBAR ══════════ */
.s-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:14px;box-shadow:0 2px 8px rgba(0,0,0,.07)}
body.theme-ai     .s-card{box-shadow:none}
body.theme-sports .s-card{box-shadow:none;background:var(--surface)}
body.theme-world  .s-card{border-radius:0}
.s-title{font-family:var(--df);font-size:13px;font-weight:700;color:var(--ink);margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid var(--border)}
body.theme-ai    .s-title{font-family:var(--mono);font-weight:500;font-size:11px;letter-spacing:.04em;color:#00d4c8}
body.theme-world .s-title{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:11px}
body.theme-sports .s-title{font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:15px;color:#f0c000}
.arch-item{padding:9px 0;border-bottom:1px solid var(--border);cursor:pointer}
.arch-item:last-child{border-bottom:none;padding-bottom:0}
.arch-date{font-size:11px;font-weight:700;color:var(--accent);margin-bottom:2px}
body.theme-ai .arch-date{font-family:var(--mono);font-weight:500}
body.theme-world .arch-date{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
.arch-hl{font-size:11px;color:var(--ink-3);line-height:1.5}
.arch-item.today .arch-date::after{content:" — Today";color:var(--green)}
.cat-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);cursor:pointer;-webkit-tap-highlight-color:transparent}
.cat-row:last-child{border-bottom:none}
.cat-name{font-size:13px;color:var(--ink-2)}
body.theme-world  .cat-name{font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.04em}
body.theme-sports .cat-name{font-family:'DM Sans',sans-serif;font-weight:600}
.cat-pill{font-size:10px;font-weight:700;background:var(--surface-3);color:var(--ink-3);padding:2px 8px;border-radius:20px}
body.theme-ai    .cat-pill{font-family:var(--mono);border-radius:3px}
body.theme-world .cat-pill{border-radius:2px}
.qr-grid{font-size:12px;color:var(--ink-3);line-height:2}
.qr-grid strong{color:var(--ink)}
.update-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:14px}
body.theme-ai      .update-box{border-color:rgba(0,212,200,.15)}
body.theme-finance .update-box{background:#0f2b1f;border-color:rgba(212,168,67,.2)}
body.theme-world   .update-box{border-radius:0;border-left:4px solid #d41f1f}
body.theme-sports  .update-box{border-color:rgba(240,192,0,.2)}
.update-box-title{font-size:12px;font-weight:700;margin-bottom:10px}
body.theme-ai      .update-box-title{color:#00d4c8;font-family:var(--mono)}
body.theme-finance .update-box-title{color:#d4a843}
body.theme-world   .update-box-title{font-family:'DM Sans',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:11px}
body.theme-sports  .update-box-title{color:#f0c000;font-family:'Bebas Neue',sans-serif;letter-spacing:.08em;font-size:15px}
.update-step{font-size:11px;line-height:1.7;padding:5px 0;border-bottom:1px solid rgba(0,0,0,.06);color:var(--ink-2)}
.update-step:last-child{border-bottom:none}
body.theme-ai .update-step{font-family:var(--mono);font-size:10px;color:var(--ink-2);border-bottom-color:rgba(255,255,255,.06)}
body.theme-finance .update-step{color:rgba(255,255,255,.6);border-bottom-color:rgba(255,255,255,.07)}
body.theme-finance .update-step strong{color:rgba(255,255,255,.9)}
body.theme-sports .update-step{color:var(--ink-2);border-bottom-color:rgba(255,255,255,.06)}
/* Sidebar responsive */
.sidebar-top-row{display:none}
@media(max-width:820px){
  .sidebar-top-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px}
  #desktopSidebar .s-card.sddup{display:none}
}
@media(max-width:480px){.sidebar-top-row{grid-template-columns:1fr}}

/* ══════════ MODAL ══════════ */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;align-items:center;justify-content:center;padding:20px}
.modal-bg.show{display:flex}
.modal{background:var(--surface);border-radius:var(--r);padding:24px;max-width:480px;width:100%;box-shadow:0 8px 32px rgba(0,0,0,.25);animation:modal-in .2s ease;max-height:90vh;overflow-y:auto}
body.theme-ai    .modal{border:1px solid rgba(0,212,200,.2)}
body.theme-world .modal{border-radius:0;border-top:4px solid #d41f1f}
body.theme-sports .modal{border:1px solid rgba(240,192,0,.2)}
@keyframes modal-in{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.modal-title{font-family:var(--df);font-size:17px;font-weight:700;color:var(--ink);margin-bottom:6px}
