/* ═══ TAB SWITCHING ═══ */
const RENDERERS = { ai:renderAI, finance:renderFinance, world:renderWorld, india:renderIndia, sports:renderSports };
let currentTab = 'ai';

async function switchTab(key) {
  currentTab = key;
  const cfg = TABS[key];
  document.getElementById('appBody').className    = cfg.theme;
  document.getElementById('logoIcon').textContent = cfg.icon;
  document.getElementById('logoText').innerHTML   = cfg.logoTxt;
  document.getElementById('tickerLabel').textContent = cfg.tLabel;
  document.getElementById('ftBrand').textContent  = cfg.ftBrand;
  document.getElementById('ftSrc').textContent    = cfg.ftSrc;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === key));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === 'panel-' + key));
  if (!CACHE[key === 'ai' || key === 'tech' ? 'ai' : key]) {
    await RENDERERS[key]();
  } else {
    const d = CACHE[key === 'sports' ? 'sports' : key] || CACHE['ai'];
    if (d && d.meta) {
      setTicker(d.meta.ticker);
      document.getElementById('editionPill').textContent = d.meta.editionLabel;
    }
  }
}
document.querySelectorAll('.tab-btn').forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));

/* ═══ MULTIBAGGER RENDERER ═══ */
function renderMultibaggars(stocks) {
  const grid = document.getElementById('mbGrid');
  const disc = document.getElementById('mbDisclaimer');
  if (!grid) return;
  if (!stocks || !stocks.length) { grid.innerHTML = '<div style="text-align:center;padding:30px;color:var(--ink-3)">No multibagger data available.</div>'; return; }

  grid.innerHTML = '';
  stocks.forEach(s => {
    const card = document.createElement('div');
    card.className = 'mb-card';
    card.innerHTML = `
      <div class="mb-hdr">
        <div class="mb-rank">${s.rank}</div>
        <div class="mb-main">
          <div class="mb-tag-row">
            <span class="mb-tag">${s.tag}</span>
            <span class="mb-ticker">${s.ticker}</span>
            <span class="mb-mcap">${s.mcap}</span>
          </div>
          <div class="mb-name">${s.name}</div>
          <div class="mb-sector">${s.sector} · CMP ${s.cmp}</div>
          <div class="mb-metric">${s.keyMetric}</div>
        </div>
        <div class="mb-chevron">⌄</div>
      </div>
      <div class="mb-body">
        <p class="mb-thesis">${s.thesis}</p>
        <div class="mb-row">
          <div class="mb-cell">
            <div class="mb-cell-label">Investment horizon</div>
            <div class="mb-cell-val">${s.horizon}</div>
          </div>
          <div class="mb-cell">
            <div class="mb-cell-label">Key metric</div>
            <div class="mb-cell-val">${s.keyMetric}</div>
          </div>
        </div>
        <div class="mb-risk">${s.risk}</div>
      </div>`;
    card.querySelector('.mb-hdr').addEventListener('click', () => card.classList.toggle('open'));
    grid.appendChild(card);
  });

  if (disc) disc.textContent = 'Multibagger research is sourced from publicly available analyst reports and is presented for informational purposes only. This is not investment advice. Past performance does not guarantee future returns. Please consult a SEBI-registered financial advisor before investing.';
}

