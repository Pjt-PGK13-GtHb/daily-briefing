function openRefreshModal() {
  const isFinance = currentTab === 'finance';
  const isAI      = currentTab === 'ai';
  document.getElementById('mTitle').textContent = '↻ Refresh Today\'s Briefing';
  if (isFinance) {
    document.getElementById('mSub').textContent = 'Choose what to refresh for the Finance tab:';
    document.getElementById('mContent').innerHTML = `
      <div class="modal-opt-group">
        <div class="modal-opt" onclick="showPrompt('rates')"><div class="modal-opt-title">₹ Rates only — cheapest</div><div class="modal-opt-desc">Just Sensex, Nifty, Gold & Silver (~2,500 tokens)</div></div>
        <div class="modal-opt" onclick="showPrompt('finance')"><div class="modal-opt-title">📰 Full Finance refresh</div><div class="modal-opt-desc">All 8 stories + rates + ETFs/MFs (~8,000 tokens)</div></div>
        <div class="modal-opt" onclick="showPrompt('all')"><div class="modal-opt-title">↻ Refresh all 5 tabs</div><div class="modal-opt-desc">Everything in one Claude session (~18,000 tokens)</div></div>
      </div>`;
    document.getElementById('mBtns').innerHTML = `<button class="mbtn mbtn-g" onclick="closeModal()">Close</button>`;
  } else if (isAI) {
    document.getElementById('mSub').textContent = 'Choose what to refresh:';
    document.getElementById('mContent').innerHTML = `
      <div class="modal-opt-group">
        <div class="modal-opt" onclick="showPrompt('ai')"><div class="modal-opt-title">⚡ AI & Tech only</div><div class="modal-opt-desc">7 AI + 5 Tech stories (~8,000 tokens)</div></div>
        <div class="modal-opt" onclick="showPrompt('all')"><div class="modal-opt-title">↻ Refresh all 5 tabs</div><div class="modal-opt-desc">Everything in one Claude session (~18,000 tokens)</div></div>
      </div>`;
    document.getElementById('mBtns').innerHTML = `<button class="mbtn mbtn-g" onclick="closeModal()">Close</button>`;
  } else {
    showPrompt(currentTab);
  }
  document.getElementById('modalBg').classList.add('show');
}

function showPrompt(key) {
  const p = PROMPTS[key] || PROMPTS.ai;
  document.getElementById('mTitle').textContent = key === 'all' ? '↻ Refresh all tabs' : `↻ Refresh ${key.charAt(0).toUpperCase()+key.slice(1)}`;
  document.getElementById('mSub').textContent   = 'Copy this prompt and paste it into Claude. Save the returned JSON to the data/ folder.';
  document.getElementById('mContent').innerHTML = `<div class="modal-prompt" id="promptBox" onclick="legacyCopy(this)" tabindex="0">${p}</div><div class="modal-hint">Tap the box to select · or use the copy button</div>`;
  document.getElementById('mBtns').innerHTML    = `<button class="mbtn mbtn-p" onclick="copyPrompt()">📋 Copy</button><a class="mbtn mbtn-p" href="https://claude.ai/new" target="_blank">Open Claude ↗</a><button class="mbtn mbtn-g" onclick="closeModal()">Close</button>`;
}

function closeModal()           { document.getElementById('modalBg').classList.remove('show'); }
function closeModalOnBg(e)      { if (e.target.id === 'modalBg') closeModal(); }
function legacyCopy(node)       { const r=document.createRange();r.selectNodeContents(node);const s=window.getSelection();s.removeAllRanges();s.addRange(r);try{document.execCommand('copy')}catch(e){}finally{s.removeAllRanges()} }
function copyPrompt()           {
  const node = document.getElementById('promptBox');
  if (!node) return;
  const txt = node.textContent;
  if (navigator.clipboard && window.isSecureContext) {
    navigator.clipboard.writeText(txt).then(()=>toast('✓ Prompt copied!'), ()=>{legacyCopy(node);toast('✓ Prompt copied!')});
  } else { legacyCopy(node); toast('✓ Prompt copied!'); }
}
function toast(msg) {
  const t = document.getElementById('copyToast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

