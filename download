<script>
/* ═══ TAG MAP ═══ */
const TM = {
  geo:'t-geo',regulation:'t-reg',bigtech:'t-big',research:'t-res',
  biz:'t-biz',startup:'t-sta',viral:'t-vir',market:'t-mkt',gold:'t-gld',
  global:'t-glo',conflict:'t-con',politics:'t-pol',culture:'t-cul',
  education:'t-edu',civic:'t-civ',govt:'t-gov',sports:'t-spt',
  cricket:'t-cri',football:'t-fbl',tennis:'t-ten',f1:'t-f1'
};

/* ═══ TAB CONFIG ═══ */
const TABS = {
  ai:      {theme:'theme-ai',      icon:'⚡', logoTxt:'AI<em>Daily</em>',      tLabel:'AI Feed', ftBrand:'⚡ AIDaily',      ftSrc:'WIRED · Korea JoongAng Daily · CNBC · MacRumors · Anthropic · Crescendo AI'},
  finance: {theme:'theme-finance', icon:'₹',  logoTxt:'Money<em>Daily</em>',   tLabel:'Markets', ftBrand:'₹ MoneyDaily',    ftSrc:'HDFC Sky · Goodreturns · BankBazaar · Trading Economics · Reuters'},
  world:   {theme:'theme-world',   icon:'🌍', logoTxt:'WORLD<em>DAILY</em>',   tLabel:'World',   ftBrand:'WORLDDAILY',      ftSrc:'CNN · Al Jazeera · BBC · Reuters · NPR · The Guardian'},
  india:   {theme:'theme-india',   icon:'🇮🇳', logoTxt:'India<em>Daily</em>', tLabel:'India',   ftBrand:'🇮🇳 IndiaDaily', ftSrc:'The Hindu · Times of India · LiveChennai · DTNext · NDTV'},
  sports:  {theme:'theme-sports',  icon:'🏆', logoTxt:'SPORTS',               tLabel:'Sports',  ftBrand:'SPORTSDAILY',     ftSrc:'ESPNcricinfo · ICC · Sky Sports · F1.com · LiveScore · Yahoo Sports'}
};

/* ═══ DATA CACHE ═══ */
const CACHE = {};

/* ═══ LOAD DATA ═══ */
async function loadData(tab) {
  if (CACHE[tab]) return CACHE[tab];
  try {
    const r = await fetch(`data/${tab}.json?v=${Date.now()}`);
    if (!r.ok) throw new Error(`HTTP ${r.status}`);
    CACHE[tab] = await r.json();
    return CACHE[tab];
  } catch(e) {
    console.error('Load failed:', tab, e);
    return null;
  }
}

/* ═══ CARD BUILDER ═══ */
function buildCards(listId, stories, filter) {
  const el = document.getElementById(listId);
  if (!el) return;
  el.innerHTML = '';
  if (!stories || !stories.length) { el.innerHTML = '<div class="loading-overlay"><div class="loading-text">No stories available.</div></div>'; return; }
  const shown = filter === 'all' ? stories : stories.filter(s => s.tags.includes(filter));
  if (!shown.length) { el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--ink-3)">No stories in this category today.</div>'; return; }
  shown.forEach(s => {
    const tags  = s.tags.map((t,i) => `<span class="tag ${TM[t]||''}">${s.tLabels[i]}</span>`).join('');
    const links = (s.links||[]).map(l => `<a class="lnk" href="${l.url}" target="_blank" rel="noopener"><div class="lnk-icon ${l.type}">${l.icon}</div><div><div class="lnk-name">${l.label}</div><div class="lnk-kind">${l.type==='yt'?'YouTube':'Article'}</div></div></a>`).join('');
    const path  = (s.path||[]).map(p => `<a class="lstep" href="${p.url}" target="_blank" rel="noopener"><div class="lstep-num">${p.n}</div><div class="lstep-body"><div class="lstep-title">${p.title}</div><div class="lstep-desc">${p.desc}</div></div><div class="lstep-arr">→</div></a>`).join('');
    const card = document.createElement('div');
    card.className = 'card';
    card.innerHTML = `
      <div class="card-hdr">
        <div class="card-num">${s.rank}</div>
        <div class="card-main"><div class="tag-row">${tags}</div><div class="card-title">${s.emoji} ${s.title}</div><div class="card-why">${s.why}</div></div>
        <div class="chevron">⌄</div>
      </div>
      <div class="card-body">
        <div class="blabel">Summary</div><p class="btext">${s.summary}</p>
        <div class="blabel" style="margin-top:14px">My take</div><div class="my-take">${s.take}</div>
        ${links ? `<div class="blabel" style="margin-top:14px">Explore further</div><div class="links-grid">${links}</div>` : ''}
        ${path  ? `<div class="blabel" style="margin-top:14px">🎓 Learning path</div><div class="lpath">${path}</div>` : ''}
      </div>`;
    card.querySelector('.card-hdr').addEventListener('click', () => card.classList.toggle('open'));
    el.appendChild(card);
  });
}

/* ═══ FILTER BAR ═══ */
function mkFilterBar(barId, cats, onFilter) {
  const bar = document.getElementById(barId);
  if (!bar) return;
  bar.innerHTML = '';
  [{ label:'All', f:'all' }, ...cats].forEach(c => {
    const b = document.createElement('button');
    b.className = 'fbtn' + (c.f === 'all' ? ' on' : '');
    b.dataset.f = c.f;
    b.textContent = c.label + (c.n ? ` ${c.n}` : '');
    b.addEventListener('click', () => {
      bar.querySelectorAll('.fbtn').forEach(x => x.classList.toggle('on', x.dataset.f === c.f));
      onFilter(c.f);
    });
    bar.appendChild(b);
  });
}

/* ═══ SIDEBAR HELPERS ═══ */
function archiveHTML(entries) {
  return entries.map(e => `<div class="arch-item${e.today?' today':''}"><div class="arch-date">${e.date}</div><div class="arch-hl">${e.hl}</div></div>`).join('') +
    `<div class="arch-item" style="opacity:.4"><div class="arch-date">Next edition</div><div class="arch-hl">Tap Refresh each morning at 7 AM IST</div></div>`;
}
function catHTML(cats, tabKey) {
  const total = cats.reduce((a,c)=>a+c.n,0);
  return cats.map(c => `<div class="cat-row" onclick="fStory('${tabKey}','${c.f}')"><span class="cat-name">${c.label}</span><span class="cat-pill">${c.n}</span></div>`).join('') +
    `<div class="cat-row" onclick="fStory('${tabKey}','all')"><span class="cat-name">🔁 Show all</span><span class="cat-pill">${total}</span></div>`;
}
function updateBoxHTML() {
  return `<div class="update-box"><div class="update-box-title">📋 Daily update guide</div>
    <div class="update-step"><strong>Step 1:</strong> Tap Refresh (top right)</div>
    <div class="update-step"><strong>Step 2:</strong> Choose what to refresh → copy prompt</div>
    <div class="update-step"><strong>Step 3:</strong> Paste in Claude → save returned JSON to data/ folder</div>
    <div class="update-step"><strong>Auto:</strong> Use GitHub Actions for one-button refresh — see refresh.yml</div>
  </div>`;
}

/* ═══ FILTER PROXY ═══ */
function fStory(tab, f) {
  if (!CACHE[tab]) return;
  if (tab === 'ai')       buildCards('storiesList-ai',      CACHE.ai.ai,       f);
  if (tab === 'tech')     buildCards('storiesList-tech',    CACHE.ai.tech,     f);
  if (tab === 'finance')  buildCards('storiesList-finance', CACHE.finance.stories, f);
  if (tab === 'world')    buildCards('storiesList-world',   CACHE.world.stories, f);
  if (tab === 'india')    buildCards('storiesList-india',   CACHE.india.india, f);
  if (tab === 'chennai')  buildCards('storiesList-chennai', CACHE.india.chennai, f);
  ['filterBar-ai','filterBar-tech','filterBar-finance','filterBar-world','filterBar-india','filterBar-chennai']
    .forEach(id => { const b = document.getElementById(id); if(b) b.querySelectorAll('.fbtn').forEach(x => x.classList.toggle('on', x.dataset.f === f)); });
}

/* ═══ TICKER ═══ */
function setTicker(items) {
  document.getElementById('tickerTrack').innerHTML = [...items,...items].map(t=>`<span>${t}</span>`).join('');
}

/* ═══ RENDER: AI ═══ */
async function renderAI() {
  document.getElementById('storiesList-ai').innerHTML = '<div class="loading-overlay"><div class="spinner"></div><div class="loading-text">Loading AI stories…</div></div>';
  const d = await loadData('ai');
  if (!d) { document.getElementById('storiesList-ai').innerHTML = '<div class="loading-overlay"><div class="loading-text">Could not load data/ai.json</div></div>'; return; }
  const m = d.meta;
  document.getElementById('ai-title').innerHTML   = `AI &amp; Technology<br><em>${m.date}</em>`;
  document.getElementById('ai-trend').innerHTML   = `<strong>Today in AI &amp; Tech:</strong> ${m.trendLine}`;
  document.getElementById('ai-sod').innerHTML     = `<div class="sod-label">⭐ Biggest story of the day</div><div class="sod-title">${m.sodTitle}</div><div class="sod-body">${m.sodBody}</div>`;
  document.getElementById('editionPill').textContent = m.editionLabel;
  setTicker(m.ticker);
  mkFilterBar('filterBar-ai',   m.aiCats,   f => buildCards('storiesList-ai',   d.ai,   f));
  mkFilterBar('filterBar-tech', m.techCats, f => buildCards('storiesList-tech',  d.tech, f));
  buildCards('storiesList-ai',   d.ai,   'all');
  buildCards('storiesList-tech', d.tech, 'all');
  // Desktop sidebar
  document.getElementById('desktopSidebar').innerHTML = updateBoxHTML() +
    `<div class="s-card sddup"><div class="s-title">📁 Archive</div>${archiveHTML(m.archiveEntries)}</div>` +
    `<div class="s-card sddup"><div class="s-title">📂 Browse AI</div>${catHTML(m.aiCats,'ai')}</div>` +
    `<div class="s-card sddup"><div class="s-title">💻 Browse Tech</div>${catHTML(m.techCats,'tech')}</div>`;
  // Mobile sidebar
  document.getElementById('ai-mob-side').innerHTML =
    `<div class="s-card"><div class="s-title">📁 Archive</div>${archiveHTML(m.archiveEntries)}</div>` +
